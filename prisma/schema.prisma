generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Modèl User
model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  telephone            String    @default("")
  adress               String    @default("")
  isEmailConfirmed     Boolean   @default(false)
  confirmationToken    String?
  role                 UserRole  @default(CUSTOMER)
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  provider             String    @default("local")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile   Profile?
  likes     Like[]
  playlists Playlist[]
}

// 2. Modèl Profile
model Profile {
  id        String  @id @default(uuid())
  username  String? @unique
  avatarUrl String?
  bannerUrl String?
  bio       String? @db.Text
  location  String?
  isArtist  Boolean @default(false)
  verified  Boolean @default(false)

  socialLinks Json? @default("{\"instagram\": \"\", \"facebook\": \"\", \"youtube\": \"\", \"tiktok\": \"\"}")

  // Relasyon User
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  // NOUVO: Yon atis ka gen plizyè tracks
  tracks    Track[]
  playlists Playlist[]
  albums    Album[]
  updatedAt DateTime   @updatedAt
}

// 3. Modèl Track (Mizik)
model Track {
  id       String  @id @default(uuid())
  title    String
  genre    String?
  audioUrl String // URL ki soti nan Supabase Storage (bucket: tracks)
  coverUrl String? // Foto kouvèti chante a
  duration Float? // Pou n konnen longè mizik la

  // Relasyon ak Atis la (Profile)
  plays     Play[] // Relasyon ak tab Play la
  playCount Int        @default(0) // Yon kontè rapid pou pèfòmans
  albumId   String?
  album     Album?     @relation(fields: [albumId], references: [id], onDelete: SetNull)
  artistId  String
  artist    Profile    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  playlists Playlist[] @relation("PlaylistTracks")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  likes     Like[]

  @@index([artistId])
}

enum UserRole {
  SUPERADMIN
  ADMIN
  CUSTOMER
  SUPERCUSTOMER
  ARTIST
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  // Mete "?" pou yo ka opsyonèl
  trackId   String?  
  track     Track?   @relation(fields: [trackId], references: [id])
  
  albumId   String?  
  album     Album?   @relation(fields: [albumId], references: [id])

  createdAt DateTime @default(now())

  // Index sa yo enpòtan pou pèfòmans ak sekirite
  @@unique([userId, trackId])
  @@unique([userId, albumId])
}

model Playlist {
  id          String  @id @default(uuid())
  name        String
  description String?
  coverUrl    String? @default("https://picsum.photos/seed/playlist/400")
  isPublic    Boolean @default(true)

  // Relasyon ak User (Owner)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relasyon ak Tracks (Many-to-Many)
  tracks Track[] @relation("PlaylistTracks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile? @relation(fields: [profileId], references: [id])
  profileId String?
}

model Play {
  id        String   @id @default(uuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String? // Nullable si moun nan pa konekte
  userIp    String? // Pou nou detekte spam menm san login
  createdAt DateTime @default(now())

  @@index([trackId, createdAt])
}

model Album {
  id          String  @id @default(uuid())
  title       String
  description String?
  coverUrl    String?
  genre       String?

  // Jesyon Piblikasyon
  releaseDate DateTime @default(now()) // Dat atis la chwazi a
  isPublished Boolean  @default(false) // De defo, li kache

  artistId String
  artist   Profile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks   Track[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  likes     Like[]

  @@index([artistId])
  @@index([releaseDate, isPublished]) // Pou rechèch rapid le n ap verifye dat yo
}
